@using Microsoft.AspNetCore.Identity;
@using System.Security.Claims;
@model ASC.Web.Areas.Accounts.Models.ServiceEngineerViewModel
@inject UserManager<IdentityUser> userManager;
@{
    Layout = "_SecureLayout";
}
<div class="row"></div>
<div class="row padding-left-20px padding-right-20px">
    <div class="row z-depth-3">
        <div class="section white-text padding-left-10px blue-grey lighten-1">
            <h5>Users</h5>
        </div>
    </div>
    <div class="divider"></div>
    <div class="col s12 padding-bottom-15px">
        @if (Model.ServiceEngineers != null)
        {
            <table class="highlight centered" id="tblServiceEngineers">
                <thead>
                    <tr>
                        <th data-field="Email">Email</th>
                        <th data-field="UserName">Name</th>
                        <th data-field="IsActive">Is Active</th>
                        <th data-field="IsActiveImg">Is Active</th>
                        <th data-field="Actions">Edit User</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.ServiceEngineers)
                    {
                        var identity = await userManager.GetClaimsAsync(user);
                        <tr>
                            <td>@user.Email</td>
                            <td>@user.UserName</td>
                            <td>
                                @(Boolean.Parse(identity.SingleOrDefault(p => p.Type == "IsActive")?.Value ?? "false"))
                            </td>
                            <td>
                                <img src="@(Boolean.Parse(identity.SingleOrDefault(p => p.Type == "IsActive")?.Value ?? "false") ? "/images/green_tick.png" : "/images/red_cross.png")" style="width: 35px; height: auto; object-fit: contain;" />
                            </td>
                            <td>
                                <i class="small material-icons edit cursor-hand">
                                    mode_edit
                                </i>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="card blue-grey lighten-1">
                <div class="card-content white-text">
                    <span class="card-title">No Service Engineers!!!</span>
                    <p>
                        No Service Engineers found, please add a Service Engineer to system.
                    </p>
                </div>
            </div>
        }
    </div>
    <div class="row"></div>

    @* Details Section *@
    <div class="row z-depth-3">
        <div class="col s12 padding-0px">
            <div class="section white-text padding-left-10px blue-grey lighten-1">
                <h5>Service Engineer Details</h5>
            </div>
            <div class="divider"></div>
            <form asp-controller="Account" asp-action="ServiceEngineers" method="post" class="col s12" id="fromUser">
                <input type="hidden" asp-for="Registration.IsEdit" />

                <div class="input-field col s4">
                    <input asp-for="Registration.Email" />
                    <label asp-for="Registration.Email"></label>
                    <span asp-validation-for="Registration.Email" class="text-danger" style="font-size: 12px;"></span>
                </div>
                <div class="input-field col s4">
                    <input asp-for="Registration.UserName" class="validate" />
                    <label asp-for="Registration.UserName"></label>
                    <span asp-validation-for="Registration.UserName" class="text-danger" style="font-size: 12px;"></span>
                </div>
                <div class="input-field col s4">
                    <input asp-for="Registration.Password" class="validate" />
                    <label asp-for="Registration.Password"></label>
                    <span asp-validation-for="Registration.Password" class="text-danger" style="font-size: 12px;"></span>
                </div>
                <div class="input-field col s4">
                    <input asp-for="Registration.ConfirmPassword" class="validate" />
                    <label asp-for="Registration.ConfirmPassword"></label>
                    <span asp-validation-for="Registration.ConfirmPassword" class="text-danger" style="font-size: 12px;"></span>
                </div>
                <div class="input-field col s4">
                    <div class="switch">
                        <label>
                            Is Active
                            <input asp-for="Registration.IsActive" class="validate" />
                            <span class="lever"></span>
                        </label>
                    </div>
                </div>
                <div class="input-field col s4 right-align">
                    <button class="btn waves-effect waves-light btnSubmit" type="submit" name="action">
                        Create
                        <i class="material-icons right">send</i>
                    </button>
                    <button class="btn waves-effect waves-light reset red lighten-1" type="button">
                        Reset
                    </button>
                </div>
                <div class="row col s12 right-align" asp-validation-summary="ModelOnly" class="text-danger"></div>
            </form>
        </div>
        <div class="row"></div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <style>
        /* Thêm CSS để biến toàn bộ hàng thành nút click và highlight hàng đang chọn */
        #tblServiceEngineers tbody tr {
            cursor: pointer;
        }

        .active-row {
            background-color: #cfd8dc !important; /* Màu xám sáng highlight */
        }
    </style>

    <script>
        $(document).ready(function () {
            var table = $('#tblServiceEngineers').DataTable({
                'pageLength': 3,
                'lengthMenu': [[3, 5, 10, -1], [3, 5, 10, 'All']]
            });
            $('#tblServiceEngineers').css("width", "100%");
            $('select[name="tblServiceEngineers_length"]').formSelect();

            // Ẩn cột IsActive (index 2)
            var isActiveColumn = table.column(2);
            isActiveColumn.visible(false);

            // Nút Reset / Cancel - Quay về mode Thêm mới (Create Mode)
            $(document).on("click", ".reset", function () {
                $('#fromUser')[0].reset();
                $('#Registration_Email').removeAttr('readonly');
                $('.btnSubmit').text('Create');
                $('#Registration_IsEdit').val('False');
                $('.text-danger').text('');
                $('#tblServiceEngineers tbody tr').removeClass('active-row'); // Gỡ highlight
                M.updateTextFields(); // Reset lại Label UI của Materialize
            });

            if ($('#Registration_IsEdit').val() === 'True') {
                $('#Registration_Email').attr('readonly', 'readonly');
            }

            // Click vào CẢ HÀNG để Edit (không cần nhắm chuẩn icon edit nữa)
            $('#tblServiceEngineers tbody').on('click', 'tr', function () {
                var tr = $(this);

                // Fix lỗi không click được ở màn hình nhỏ/ẩn danh (DataTables Responsive Child Row)
                if (tr.hasClass('child')) {
                    tr = tr.prev('.parent');
                }

                var user = table.row(tr).data();
                if(!user) return;

                // Đổi màu highlight cho hàng đang được chọn
                $('#tblServiceEngineers tbody tr').removeClass('active-row');
                tr.addClass('active-row');

                $('#Registration_IsEdit').val('True');

                $('#Registration_Email').val($.trim(user[0]));
                $('#Registration_Email').attr('readonly', 'readonly');

                $('#Registration_UserName').val($.trim(user[1]));
                $('#Registration_UserName').addClass('valid');

                var isActive = $.trim(user[2]).toLowerCase();
                $('#Registration_IsActive').prop('checked', isActive === 'true');

                $('.btnSubmit').text('Save');
                M.updateTextFields();
            });
        });
    </script>
}