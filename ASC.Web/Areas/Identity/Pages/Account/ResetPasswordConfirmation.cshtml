@page
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Password Reset Successful";
}

<div class="container" style="margin-top: 50px; margin-bottom: 50px;">
    <div class="row">
        <div class="col s12 m6 offset-m3">
            <div class="card">
                <div class="card-content center-align">
                    <i class="material-icons large green-text">check_circle</i>

                    <span class="card-title" style="margin-top: 15px; font-weight: bold;">
                        @ViewData["Title"]
                    </span>

                    <p style="margin-top: 10px; font-size: 1.1em;">
                        Your password has been reset successfully. You can now access your account with the new password.
                    </p>
                </div>

                <div class="card-action center-align">
                    <a asp-page="./Login" class="btn waves-effect waves-light teal">
                        Click here to Log in
                        <i class="material-icons right">login</i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>